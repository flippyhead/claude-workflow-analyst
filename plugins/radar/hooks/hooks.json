{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/install.mjs\" && node \"${CLAUDE_PLUGIN_ROOT}/hooks/first-run.mjs\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
